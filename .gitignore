# --- PowerShell/Directives ---
# Ignore PowerShell history and temporary session files
.history
*.log
*.pfx
*.txt

# --- Script Specifics ---
# Ignore the actual diagnostic reports generated by the script
# This prevents your personal network test results from being uploaded
*_tnctest_report.txt

# --- Editor/IDE Specifics ---
# Visual Studio Code
.vscode/
bin/
obj/

# JetBrains (IntelliJ, Rider, etc.)
.idea/

# --- System Files ---
# Windows thumbnail cache and folder settings
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS system files (if you ever edit on a Mac)
.DS_Store
.AppleDouble
.LSOverride
